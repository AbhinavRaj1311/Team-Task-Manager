# Backend environment
PORT=5000
# MongoDB Atlas note: connecting from code ALWAYS uses a *database user + password*.
# Your Google login is only for the Atlas web UI.
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster-host>/ETHARA?retryWrites=true&w=majority
# Optional (forces the db name even if URI omits it)
MONGODB_DBNAME=ETHARA
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRE=7d

# Seed a default admin user on startup (first boot only)
SEED_DEFAULT_ADMIN=true
DEFAULT_ADMIN_NAME=Admin
DEFAULT_ADMIN_EMAIL=admin@local.test
DEFAULT_ADMIN_PASSWORD=Admin@12345
# In production, password reset is only done when explicitly enabled.
DEFAULT_ADMIN_RESET_PASSWORD=true

# Comma-separated allowed frontend origins for CORS
# Examples:
# CLIENT_URL=http://localhost:5173
# CLIENT_URL=https://your-frontend.up.railway.app
CLIENT_URL=http://localhost:5173
